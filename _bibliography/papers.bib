% Published Papers

@article{wen2021scheduling,
  abbr        = {COR},
  bibtex_show = {true},
  title       = {Scheduling interrelated activities in complex projects under high-order rework: A DSM-based approach},
  author      = {Wen, Muchen and Lin, Jun and Qian, Yanjun and Huang, Weihao},
  journal     = {Computers \& Operations Research},
  year        = {2021},
  volume      = {136},
  pages       = {105494},
  publisher   = {Elsevier},
  doi         = {10.1016/j.cor.2021.105494},
  selected    = {true},
  category    = {Published},
  abstract    = {Proposes a novel objective function (FSRT) that captures both first- and second-order rework in complex projects. Develops exact and heuristic algorithms validated across four real-world projects, achieving significantly more rework reduction than prior DSM-based scheduling methods. For instances with 30 activities at 0.5 density, the best prior method achieves only 80% of the rework reduction possible with FSRT.}
}

@article{lin2020covid,
  abbr        = {STOTEN},
  bibtex_show = {true},
  title       = {Containing the spread of coronavirus disease 2019 (COVID-19): Meteorological factors and control strategies},
  author      = {Lin, Jun and Huang, Weihao and Wen, Muchen and Li, Dehong and Ma, Shuyi and Hua, Jiawen and Tian, Yiran},
  journal     = {Science of The Total Environment},
  year        = {2020},
  volume      = {739},
  pages       = {140053},
  publisher   = {Elsevier},
  doi         = {10.1016/j.scitotenv.2020.140053},
  selected    = {true},
  category    = {Published},
  abstract    = {Extends the SEIR model to incorporate pre-symptomatic transmission using data from 11 Chinese provinces and 69 countries. Finds that pre-symptomatic spread critically undermines conventional control measures — the effective reproduction number becomes 130% higher — and reveals a temperature-dependent effect of humidity on COVID-19 transmission.}
}

% Working Papers - Under Review

@article{wen2024boosting,
  abbr        = {POM},
  bibtex_show = {true},
  title       = {Boosting and Burdening: Dual Spillover Effects of Bike-Sharing Networks on Home-Sharing Performance},
  author      = {Wen, Muchen and Liu, Junming and Kwon, Juhee and Jung, Kyung Sung and Kwark, Young},
  journal     = {Production and Operations Management},
  year        = {2024},
  status      = {Under Review},
  award       = {ICIS 2023 Best Student Paper Award Nomination},
  award_name  = {Best Student Paper Nomination},
  selected    = {true},
  category    = {Under Review},
  abstract    = {Studies how bike-sharing network expansion generates cross-market spillovers for Airbnb using a staggered DiD design across three expansion waves in NYC. Finds that properties in newly served areas gain 13.5% in monthly revenue, while those in existing connected areas lose 16.9% — driven by location advantage gains versus intensified spatial competition. Decomposes mechanisms into destination flexibility, time efficiency, and cost efficiency.}
}

@article{zhan2024protecting,
  abbr        = {DS},
  bibtex_show = {true},
  title       = {Protecting You, Threatening Your Property: Impacts of Bike-Sharing on Urban Crime},
  author      = {Zhan, Baozhen and Wang, Yulan and Feng, Gengzhong and Wen, Muchen and Lin, Jun},
  journal     = {Decision Sciences},
  year        = {2024},
  status      = {Under Review},
  note        = {*Corresponding author},
  category    = {Under Review},
  abstract    = {Documents a paradoxical dual effect of bike-sharing: personal crime declines by 5.3% while nighttime property crime increases by 3.6% in NYC. Finds that intensive policing amplifies both effects, revealing the inadequacy of traditional policing against stealthy, dispersed bike-enabled crimes. Advances Routine Activity Theory by showing how a single infrastructure differentially alters crime convergence conditions.}
}

% Working Papers - In Preparation

@article{wen2024rethinking,
  abbr        = {JMR},
  bibtex_show = {true},
  title       = {Rethinking Conventional Wisdom: The Net Spillover Effect of Bike Sharing Entry on Restaurant Patronage},
  author      = {Wen, Muchen and Liu, Junming and Foutz, Natasha Zhang and Sun, Baohong},
  journal     = {Journal of Marketing Research},
  year        = {2024},
  status      = {In Preparation},
  selected    = {true},
  category    = {Working Papers},
  abstract    = {Challenges the assumption that bike-sharing universally benefits local businesses. Using 3+ billion location pings from 1.27M residents across 20,000+ restaurants, reveals a "siphon phenomenon": in disadvantaged neighborhoods, outward substitution dominates, causing a net decline in patronage that exacerbates regional inequality. First study to directly observe opposing consumer-level substitution mechanisms at individual level.}
}

@article{zhan2024share,
  abbr        = {MSOM},
  bibtex_show = {true},
  title       = {Share the Sharing: Spillover Effects of Bike-Sharing on Local Taxi Markets and Driver Welfare},
  author      = {Zhan, Baozhen and Wang, Yulan and Wen, Muchen},
  journal     = {Manufacturing \& Service Operations Management},
  year        = {2024},
  status      = {In Preparation},
  award       = {IJOPM Hong Kong Workshop 2026 Best Paper Award},
  award_name  = {Best Paper Award},
  note        = {Presented at POMS-HK International Conference 2026},
  category    = {Working Papers},
  abstract    = {Proposes a novel Taxi Accessibility Index (TAI) that predicts where bike-sharing substitutes vs. complements taxis. Using two-level DiD (market + driver) with NYC taxi data, finds bike-sharing increases demand in high-accessibility areas but reduces it in low-accessibility ones, while compressing earnings inequality — low-skill drivers gain at the expense of high-skill drivers.}
}

@article{zhan2024safety,
  abbr        = {MSOM},
  bibtex_show = {true},
  title       = {The Safety Cost of Micro Mobility: Impact of Bike-Sharing on Traffic Accidents},
  author      = {Zhan, Baozhen and Wang, Yulan and Wen, Muchen},
  journal     = {Manufacturing \& Service Operations Management},
  year        = {2024},
  status      = {In Preparation},
  note        = {Presented at POMS-HK International Conference 2026},
  category    = {Working Papers},
  abstract    = {Identifies speed variance as a previously unrecognized negative externality of bike-sharing: introducing cyclists into motor-vehicle traffic increases speed dispersion, raising accident risk. Using continuous DiD with intensity-based treatment across 6,504 tract-month observations, finds effects concentrate among trucks and taxis, at intersections, and on medium-width roads. Only protected bike lanes mitigate the effect; estimates \$10.6–12.4M annual accident cost in NYC.}
}

